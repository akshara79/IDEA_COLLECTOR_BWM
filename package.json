{
  "name": "idea-collector-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.12.0",
    "body-parser": "^1.20.2",
    "bullmq": "^2.12.0",
    "csv-writer": "^1.6.0",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "openai": "^4.10.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "prisma": "^5.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.1"
  }
}